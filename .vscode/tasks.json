{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Vaadin Web (Jetty)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "mvn jetty:run & echo $! > .vscode/jetty.pid; wait $!"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "jetty",
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Started ServerConnector@.*0.0.0.0:8080|Started Server@"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "web"
            }
        },
        {
            "label": "Stop Vaadin Web (Jetty)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "if [[ -f .vscode/jetty.pid ]]; then kill $(cat .vscode/jetty.pid) 2>/dev/null || true; rm -f .vscode/jetty.pid; fi; pkill -f 'mvn jetty:run' 2>/dev/null || true"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "never",
                "panel": "dedicated",
                "group": "web"
            }
        }
    ]
}
